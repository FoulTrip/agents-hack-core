GEMINI_API_KEY=
GITHUB_TOKEN=
NOTION_TOKEN=
NOTION_WORKSPACE_ID=
JWT_SECRET=
JWT_ALGORITHM=
LOG_LEVEL=DEBUG
ENVIRONMENT=development
DATABASE_URL=

# Google Cloud Vertex AI Configuration
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_LOCATION=us-central1
GOOGLE_GENAI_USE_VERTEXAI=TRUE

# Local code generation (workspace mirror)
LOCAL_GENERATION_ENABLED=true
LOCAL_PROJECTS_DIR=./generated_projects

# Notion integration
# false => do not upload to Notion; generate local .md fallback files instead
NOTION_UPLOAD_ENABLED=false
